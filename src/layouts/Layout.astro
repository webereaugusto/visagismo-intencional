---
import '../styles/global.css';
import ExitPopup from '../components/ExitPopup.astro';
import Analytics from '../components/Analytics.astro';
import { siteConfig, whatsappLink, absoluteUrl } from '../config/site';
import {
  buildOrganizationSchema,
  buildHairSalonSchema,
  buildPersonSchema,
  buildWebSiteSchema,
  buildWebPageSchema,
  buildBreadcrumbSchema,
  buildServiceSchema,
  buildFAQPageSchema,
  buildArticleSchema,
} from '../utils/schema';
import { faqs } from '../config/faq';
import type { FaqItem } from '../config/faq';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  path?: string;
  breadcrumbs?: { name: string; path: string }[];
  serviceSchema?: { name: string; description: string; path: string };
  faqs?: FaqItem[];
  article?: { datePublished: string; dateModified?: string };
}

const defaultTitle = 'Visagismo Campinas | Visagismo em Campinas no Cambuí | Ery Junior';
const defaultDescription =
  'Visagismo Campinas e visagismo em Campinas no Cambuí com Ery Junior. Consultoria de imagem, análise facial, colorimetria e corte visagista. Agende pelo WhatsApp.';

const {
  title = defaultTitle,
  description = defaultDescription,
  image = siteConfig.defaultImage,
  type = 'website',
  noindex = false,
  path = '/',
  breadcrumbs,
  serviceSchema,
  faqs: pageFaqs,
  article,
} = Astro.props;

const canonicalUrl = absoluteUrl(path);
const fullImageUrl = image.startsWith('http') ? image : absoluteUrl(image);
const breadcrumbItems = breadcrumbs ?? [{ name: 'Home', path: '/' }];
const gscVerification = import.meta.env.PUBLIC_GSC_VERIFICATION;
const faqSchemaItems = pageFaqs ?? (path === '/' ? faqs : undefined);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <meta http-equiv="Content-Language" content="pt-BR" />

    <style>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:'Outfit',sans-serif;background:#0a0a0a;color:#fff;-webkit-font-smoothing:antialiased}
      img{max-width:100%;height:auto;display:block}
      #header{position:fixed;top:0;left:0;right:0;z-index:40;padding:.75rem 0}
      #hero{min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;background:#0a0a0a}
      .font-playfair{font-family:'Bodoni Moda',serif}
      .font-montserrat{font-family:'Outfit',sans-serif}
      .text-gold{color:#D4A853}
      .bg-dark{background:#0a0a0a}
      .text-white{color:#fff}
    </style>

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.author} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="pt-BR" href={canonicalUrl} />

    <meta name="geo.region" content="BR-SP" />
    <meta name="geo.placename" content="Campinas, São Paulo, Brasil" />
    <meta name="geo.position" content={`${siteConfig.address.latitude};${siteConfig.address.longitude}`} />
    <meta name="ICBM" content={`${siteConfig.address.latitude}, ${siteConfig.address.longitude}`} />
    {gscVerification && typeof gscVerification === 'string' && gscVerification.trim() && (
      <meta name="google-site-verification" content={gscVerification.trim()} />
    )}

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteConfig.siteName} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImageUrl} />
    <meta property="og:locale" content={siteConfig.locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImageUrl} />
    <meta name="twitter:domain" content="www.visagismocampinas.com.br" />

    <meta name="theme-color" content={siteConfig.themeColor} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="image" href="/images/logo-branco-500-transparente-visagismo.png" type="image/png" fetchpriority="high" />
    <link rel="preload" as="image" href="/images/baner.webp" type="image/webp" />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;0,6..96,700;1,6..96,400;1,6..96,500&family=Outfit:wght@300;400;500;600;700&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;0,6..96,700;1,6..96,400;1,6..96,500&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;0,6..96,700;1,6..96,400;1,6..96,500&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    </noscript>

    <script type="application/ld+json" set:html={JSON.stringify(buildOrganizationSchema())} />
    <script type="application/ld+json" set:html={JSON.stringify(buildHairSalonSchema(description))} />
    <script type="application/ld+json" set:html={JSON.stringify(buildPersonSchema())} />
    <script type="application/ld+json" set:html={JSON.stringify(buildWebSiteSchema(description))} />
    <script type="application/ld+json" set:html={JSON.stringify(buildWebPageSchema({ title, description, path, image }))} />
    <script type="application/ld+json" set:html={JSON.stringify(buildBreadcrumbSchema(breadcrumbItems))} />
    {serviceSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(buildServiceSchema(serviceSchema.name, serviceSchema.description, serviceSchema.path))} />
    )}
    {faqSchemaItems && faqSchemaItems.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify(buildFAQPageSchema(faqSchemaItems))} />
    )}
    {article && (
      <script type="application/ld+json" set:html={JSON.stringify(buildArticleSchema({ title, description, path, image, ...article }))} />
    )}
  </head>
  <body class="antialiased">
    <a href="#conteudo-principal" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-gold focus:text-dark focus:px-4 focus:py-2">
      Pular para o conteúdo
    </a>
    <slot />
    <a
      href={whatsappLink('Olá, gostaria de agendar uma consultoria de visagismo em Campinas')}
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 z-50 group animate-float"
      aria-label="Contato via WhatsApp"
    >
      <div class="relative">
        <div class="absolute inset-0 bg-[#25D366]/30 rounded-full blur-xl group-hover:bg-[#25D366]/50 transition-all"></div>
        <div class="relative bg-[#25D366] text-white p-4 rounded-full shadow-2xl transition-all duration-300 group-hover:scale-110">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </div>
      </div>
    </a>
    <Analytics />
    <ExitPopup />
    <script>
      const observerOptions = { root: null, rootMargin: '0px 0px -50px 0px', threshold: 0.1 };
      const animationObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add('is-visible');
        });
      }, observerOptions);
      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.animate-on-scroll, .animate-line, .animate-counter').forEach((el) => animationObserver.observe(el));
      });
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', (e) => {
          const href = anchor.getAttribute('href');
          if (!href || href === '#') return;
          const target = document.querySelector(href);
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    </script>
  </body>
</html>

<style is:global>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
  .focus\:not-sr-only:focus {
    position: static;
    width: auto;
    height: auto;
    padding: inherit;
    margin: inherit;
    overflow: visible;
    clip: auto;
    white-space: normal;
  }
</style>
