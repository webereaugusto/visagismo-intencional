---
import { siteConfig, whatsappLink } from '../config/site';

const waLink = whatsappLink('Olá, gostaria de agendar uma consultoria de visagismo em Campinas');

const diferenciais = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" /></svg>`,
    title: 'Formação Internacional',
    description: 'Certificações Vidal Sassoon (Londres), especializações em Nova York e L\'Oréal Paris, documentadas na trajetória do estúdio.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: `${siteConfig.experienceYears}+ Anos de Experiência`,
    description: 'Três décadas dedicadas ao visagismo em Campinas, com metodologia própria e atendimento personalizado.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z" /></svg>`,
    title: 'Método Autoral',
    description: 'Técnica desenvolvida ao longo de décadas que une análise facial com sensibilidade artística e projeto de imagem.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>`,
    title: 'Estúdio no Cambuí',
    description: `Espaço no bairro Cambuí, Campinas. ${siteConfig.parkingNote}`,
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>`,
    title: 'Atendimento Personalizado',
    description: 'Consultoria individual com hora marcada. Sem filas, sem pressa. Seu tempo é valorizado do início ao fim.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>`,
    title: 'Transformações Documentadas',
    description: 'Resultados reais na galeria e em estudos de caso, com foco em harmonia e identidade visual.',
  },
];
---

<section class="relative py-20 md:py-28 lg:py-36 bg-dark overflow-hidden" id="diferenciais">
  <div class="relative max-w-7xl mx-auto px-5 md:px-6">
    <div class="text-center max-w-3xl mx-auto mb-16 md:mb-20">
      <div class="flex items-center justify-center gap-3 mb-6 animate-on-scroll">
        <span class="w-10 md:w-12 h-[1px] bg-gold"></span>
        <span class="text-gold text-[10px] md:text-xs tracking-[0.2em] md:tracking-[0.3em] uppercase font-montserrat font-medium">
          Por Que Nos Escolher
        </span>
        <span class="w-10 md:w-12 h-[1px] bg-gold"></span>
      </div>
      
      <h2 class="font-playfair text-3xl md:text-5xl lg:text-6xl font-medium leading-tight mb-6 text-white animate-on-scroll animate-delay-100">
        Nossos <span class="text-gradient-gold italic">Diferenciais</span>
      </h2>
      
      <p class="font-montserrat text-gray-light text-sm md:text-base lg:text-lg leading-relaxed animate-on-scroll animate-delay-200">
        O que diferencia o <strong class="text-gold">Visagismo Intencional</strong> para quem busca
        <strong class="text-white">visagismo em Campinas</strong> com critério técnico.
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {diferenciais.map((item, index) => (
        <div class={`group relative p-6 md:p-8 border border-white/10 hover:border-gold/40 bg-white/5 backdrop-blur-sm hover:bg-white/10 transition-all duration-500 animate-on-scroll animate-delay-${(index % 3 + 1) * 100}`}>
          <div class="text-gold/70 group-hover:text-gold transition-colors duration-300 mb-6">
            <Fragment set:html={item.icon} />
          </div>
          <h3 class="font-playfair text-xl text-white mb-3 group-hover:text-gold transition-colors">
            {item.title}
          </h3>
          <p class="font-montserrat text-sm text-gray leading-relaxed">
            {item.description}
          </p>
        </div>
      ))}
    </div>
    
    <div class="mt-16 md:mt-20 text-center animate-on-scroll">
      <a 
        href={waLink}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-gradient-to-r from-gold to-gold-dark text-dark px-8 md:px-10 py-4 md:py-5 font-montserrat text-xs md:text-sm font-bold tracking-wider uppercase hover:shadow-lg hover:shadow-gold/30 transition-all"
      >
        <span>Agende sua Consultoria</span>
      </a>
    </div>
  </div>
</section>
