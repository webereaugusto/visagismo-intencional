---
import { siteConfig, whatsappLink } from '../config/site';

const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: 'Visagismo em Campinas', href: '/#resposta-local' },
  { label: 'Sobre Ery Junior', href: '/sobre/ery-junior/' },
  { label: 'Método Ery Junior', href: '/metodo-ery-junior/' },
  { label: 'Resultados', href: '/resultados/' },
  { label: 'FAQ', href: '/#faq' },
  { label: 'Contato', href: '/#contato' },
];

const serviceLinks = [
  { label: 'Consultoria de Visagismo', href: '/consultoria-de-visagismo-campinas/' },
  { label: 'Visagismo Masculino', href: '/visagismo-masculino-campinas/' },
  { label: 'Visagismo Feminino', href: '/visagismo-feminino-campinas/' },
  { label: 'Corte Visagista', href: '/corte-visagista-campinas/' },
  { label: 'Colorimetria', href: '/colorimetria-campinas/' },
];

const guideLinks = [
  { label: 'Dicas de visagismo', href: '/dicas-de-visagismo-campinas/' },
  { label: 'O que é visagismo', href: '/guia/o-que-e-visagismo/' },
  { label: 'Corte vs visagismo', href: '/guia/diferenca-corte-visagismo/' },
  { label: 'Como escolher visagista', href: '/guia/como-escolher-visagista-campinas/' },
];
---

<footer class="bg-dark-light border-t border-dark-lighter py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-12 mb-16">
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-6" aria-label="Visagismo Intencional - Página inicial">
          <img
            src="/images/logo-branco-500-transparente-visagismo.png"
            alt="Visagismo Intencional by Ery Junior - Logo"
            class="h-12 w-auto"
            loading="lazy"
            decoding="async"
            width="150"
            height="48"
          />
        </a>
        <p class="font-montserrat text-gray-light text-sm leading-relaxed mb-8">
          Estúdio de visagismo no Cambuí, Campinas, com consultoria de imagem personalizada e atendimento por hora marcada.
        </p>
        <div class="flex gap-4">
          <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-full bg-dark-lighter flex items-center justify-center text-gray hover:text-gold hover:bg-gold/10 transition-all" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href={whatsappLink('Olá, gostaria de mais informações')} target="_blank" rel="noopener noreferrer" class="w-12 h-12 rounded-full bg-dark-lighter flex items-center justify-center text-gray hover:text-gold hover:bg-gold/10 transition-all" aria-label="WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h4 class="font-montserrat text-sm font-semibold tracking-wider uppercase mb-8 text-gradient-gold">Navegação</h4>
        <ul class="space-y-4">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="font-montserrat text-sm text-gray hover:text-gold transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-montserrat text-sm font-semibold tracking-wider uppercase mb-8 text-gradient-gold">Serviços</h4>
        <ul class="space-y-4">
          {serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="font-montserrat text-sm text-gray hover:text-gold transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-montserrat text-sm font-semibold tracking-wider uppercase mb-8 text-gradient-gold">Guias</h4>
        <ul class="space-y-4">
          {guideLinks.map((link) => (
            <li>
              <a href={link.href} class="font-montserrat text-sm text-gray hover:text-gold transition-colors">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-montserrat text-sm font-semibold tracking-wider uppercase mb-8 text-gradient-gold">Contato</h4>
        <ul class="space-y-5 font-montserrat text-sm text-gray">
          <li>
            {siteConfig.address.street}<br />
            {siteConfig.address.neighborhood} - {siteConfig.address.city}, {siteConfig.address.state}
          </li>
          <li>
            <a href={`tel:${siteConfig.phoneClean}`} class="hover:text-gold transition-colors">{siteConfig.phoneDisplay}</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="w-full h-[1px] bg-gradient-to-r from-transparent via-gold/30 to-transparent mb-8"></div>
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="font-montserrat text-xs text-gray/60">&copy; {currentYear} {siteConfig.brandLine}. Todos os direitos reservados.</p>
      <p class="font-montserrat text-xs text-gray/60">Visagismo Campinas | Visagismo em Campinas | Cambuí</p>
    </div>
  </div>
</footer>
