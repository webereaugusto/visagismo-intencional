---
interface Props {
  items: { name: string; path: string }[];
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="font-montserrat text-sm text-gray">
  <ol class="flex flex-wrap items-center gap-2">
    {items.map((item, index) => (
      <li class="flex items-center gap-2">
        {index > 0 && <span aria-hidden="true" class="text-gray/50">/</span>}
        {index === items.length - 1 ? (
          <span class="text-gold" aria-current="page">{item.name}</span>
        ) : (
          <a href={item.path} class="hover:text-gold transition-colors">{item.name}</a>
        )}
      </li>
    ))}
  </ol>
</nav>
