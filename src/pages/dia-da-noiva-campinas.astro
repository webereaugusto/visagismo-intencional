---
import PageLayout from '../layouts/PageLayout.astro';
import PageCta from '../components/PageCta.astro';
import HubContext from '../components/HubContext.astro';
import { siteConfig } from '../config/site';

const path = '/dia-da-noiva-campinas/';
const title = 'Dia da Noiva em Campinas | Visagismo para Noivas no Cambuí';
const description = 'Dia da noiva em Campinas com visagismo, penteado e teste prévio no Cambuí. Atendimento exclusivo com Ery Junior para o seu grande dia. Agende pelo WhatsApp.';

const faqs = [
  {
    question: 'O que inclui o pacote dia da noiva?',
    answer: 'Teste prévio de penteado e visagismo, atendimento exclusivo no dia do casamento, suporte para ajustes finais e orientação para manter o visual durante a cerimônia e festa.',
  },
  {
    question: 'Quando devo agendar o teste prévio?',
    answer: 'Recomendamos o teste entre 30 e 60 dias antes do casamento. Assim há tempo para ajustes e para alinhar o visual com vestido, véu e maquiagem.',
  },
  {
    question: 'O visagismo da noiva inclui coloração?',
    answer: 'Se necessário, a colorimetria é feita no teste prévio para garantir que cabelo, pele e maquiagem estejam harmonizados no dia. Corte e cor são planejados com antecedência.',
  },
  {
    question: 'Atendem no estúdio ou a domicílio em Campinas?',
    answer: 'O atendimento principal é no estúdio do Cambuí. Para o dia do casamento, consulte disponibilidade de deslocamento pelo WhatsApp.',
  },
];
---

<PageLayout
  title={title}
  description={description}
  path={path}
  h1="Dia da Noiva"
  subtitle="Visagismo, penteado e teste prévio para o dia mais importante — com atendimento exclusivo no Cambuí, Campinas."
  image="/images/noiva.webp"
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Dia da Noiva', path },
  ]}
  serviceSchema={{
    name: 'Dia da Noiva em Campinas',
    description,
    path,
  }}
  faqs={faqs}
>
  <section class="py-16 bg-dark-light">
    <div class="max-w-3xl mx-auto px-5 font-montserrat text-gray-light leading-relaxed space-y-6">
      <HubContext service="dia da noiva" />

      <p>
        O dia do casamento pede mais do que um penteado bonito: pede harmonia entre rosto, cabelo, vestido, véu e maquiagem.
        No {siteConfig.brandLine}, o pacote dia da noiva começa com visagismo e teste prévio — para que no grande dia
        tudo esteja ensaiado, confortável e alinhado à sua identidade.
      </p>

      <p>
        Com mais de {siteConfig.experienceYears} anos de experiência em transformações e eventos especiais, Ery Junior conduz
        cada noiva com atendimento exclusivo no estúdio do Cambuí, Campinas. Nada é improvisado na véspera.
      </p>

      <div class="rounded-2xl overflow-hidden">
        <img
          src="/images/noiva.webp"
          alt="Visagismo para noivas em Campinas - penteado de noiva"
          class="w-full h-auto"
          loading="lazy"
          width="800"
          height="600"
        />
      </div>

      <h2 class="font-playfair text-2xl text-white">O que inclui</h2>
      <ul class="list-disc pl-5 space-y-2">
        <li>Consultoria de visagismo focada no dia do casamento</li>
        <li>Teste prévio de penteado com ajustes até o resultado ideal</li>
        <li>Alinhamento de cor e corte com antecedência, se necessário</li>
        <li>Atendimento exclusivo no dia — sem pressa, sem fila</li>
        <li>Orientação para manter o visual durante cerimônia e festa</li>
        <li>Duração estimada de 4 a 6 horas no dia do evento</li>
      </ul>

      <h2 class="font-playfair text-2xl text-white">Como funciona</h2>
      <ol class="list-decimal pl-5 space-y-3">
        <li><strong class="text-white">Primeiro contato:</strong> conversamos sobre data, horário da cerimônia, estilo do vestido e referências visuais.</li>
        <li><strong class="text-white">Teste prévio:</strong> entre 30 e 60 dias antes, testamos penteado, acessórios e harmonização com o rosto.</li>
        <li><strong class="text-white">Ajustes:</strong> refinamos o visual até você se sentir segura e confortável.</li>
        <li><strong class="text-white">Dia do casamento:</strong> execução do penteado ensaiado, com tempo reservado para imprevistos.</li>
      </ol>

      <h2 class="font-playfair text-2xl text-white">Por que visagismo para noivas</h2>
      <p>
        Penteados de tendência nem sempre valorizam o formato do rosto ou combinam com o véu e o decote do vestido.
        O visagismo analisa proporções faciais, comprimento ideal e movimento do cabelo antes de definir o penteado final.
        O resultado é um visual que parece natural em você — não uma cópia de Pinterest.
      </p>

      <h2 class="font-playfair text-2xl text-white">Serviços relacionados</h2>
      <ul class="space-y-2">
        <li><a href="/visagismo-feminino-campinas/" class="text-gold hover:underline">Visagismo feminino</a></li>
        <li><a href="/consultoria-de-visagismo-campinas/" class="text-gold hover:underline">Consultoria de visagismo</a></li>
        <li><a href="/colorimetria-campinas/" class="text-gold hover:underline">Colorimetria em Campinas</a></li>
        <li><a href="/resultados/" class="text-gold hover:underline">Resultados e estudos de caso</a></li>
      </ul>

      <h2 class="font-playfair text-2xl text-white">Perguntas frequentes</h2>
      <dl class="space-y-4 text-sm">
        {faqs.map((item) => (
          <div>
            <dt class="text-white font-medium">{item.question}</dt>
            <dd>{item.answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>
  <PageCta message="Olá, quero saber sobre o dia da noiva em Campinas" label="Agendar conversa sobre noivas" />
</PageLayout>
