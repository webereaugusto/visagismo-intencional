---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import LocalAnswer from '../components/LocalAnswer.astro';
import Stats from '../components/Stats.astro';
import WhatIsVisagismo from '../components/WhatIsVisagismo.astro';
import Metodo from '../components/Metodo.astro';
import Services from '../components/Services.astro';
import VisagismoTypes from '../components/VisagismoTypes.astro';
import Gallery from '../components/Gallery.astro';
import About from '../components/About.astro';
import Diferenciais from '../components/Diferenciais.astro';
import GoogleBusiness from '../components/GoogleBusiness.astro';
import Testimonials from '../components/Testimonials.astro';
import GuidesHub from '../components/GuidesHub.astro';
import FAQ from '../components/FAQ.astro';
import Location from '../components/Location.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header />
  <main id="conteudo-principal">
    <Hero />
    <LocalAnswer />
    <Stats />
    <WhatIsVisagismo />
    <Metodo />
    <Services />
    <VisagismoTypes />
    <Gallery />
    <About />
    <Diferenciais />
    <GoogleBusiness />
    <Testimonials />
    <GuidesHub />
    <FAQ />
    <Location />
    <Contact />
  </main>
  <Footer />
</Layout>
