---
import PageLayout from '../layouts/PageLayout.astro';
import PageCta from '../components/PageCta.astro';

const path = '/corte-visagista-campinas/';
const title = 'Corte Visagista em Campinas | Ery Junior no Cambuí';
const description = 'Corte visagista em Campinas com análise facial e design capilar personalizado. Visagismo Intencional no Cambuí com Ery Junior.';
---

<PageLayout
  title={title}
  description={description}
  path={path}
  h1="Corte Visagista em Campinas"
  subtitle="Design capilar baseado em análise facial, proporções e objetivos pessoais — não apenas em tendências passageiras."
  image="/images/autoridade.webp"
  breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Corte Visagista', path }]}
  serviceSchema={{ name: 'Corte Visagista em Campinas', description, path }}
>
  <section class="py-16 bg-dark-light">
    <div class="max-w-3xl mx-auto px-5 font-montserrat text-gray-light leading-relaxed space-y-6">
      <p>
        O corte visagista parte de um diagnóstico: formato do rosto, linha da mandíbula, testa, volume natural e estilo de vida.
        A partir disso, o corte é desenhado para equilibrar e valorizar seus traços.
      </p>
      <h2 class="font-playfair text-2xl text-white">Diferença para um corte comum</h2>
      <p>
        Enquanto o corte tradicional pode copiar uma referência da moda, o corte visagista responde à pergunta:
        qual visual comunica melhor quem você é hoje e para onde quer ir?
      </p>
      <img src="/images/autoridade.webp" alt="Corte visagista em Campinas - Ery Junior" class="rounded-xl" loading="lazy" width="800" height="600" />
    </div>
  </section>
  <PageCta message="Olá, quero agendar um corte visagista em Campinas" />
</PageLayout>
