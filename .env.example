# Google Analytics 4 — defina no painel da Vercel (Settings > Environment Variables)
PUBLIC_GA_ID=

# Após o deploy:
# 1. Search Console: adicionar propriedade www.visagismocampinas.com.br e enviar sitemap-index.xml
